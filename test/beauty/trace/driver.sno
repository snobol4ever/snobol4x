*  driver.sno — test driver for trace subsystem (B-277)
*  Oracle: snobol4 -f -P256k -Idemo/inc driver.sno
*  Run via: INC=demo/inc bash test/beauty/run_beauty_subsystem.sh trace

-INCLUDE 'global.sno'
-INCLUDE 'trace.sno'

        &STLIMIT = 1000000

        dummy     = ''
        strOfs    = 0
        t8Max     = 0
        t8MaxLine = 0
        t8MaxLast = 0
        doDebug   = 0

*  Portable DATATYPE tokens (dialect-independent)
        dSTRING   = DATATYPE('')
        dNAME     = DATATYPE(.dummy)

* -----------------------------------------------------------------------
*  1: T8Pos nil t8Map => LPAD(ofs,8)
* -----------------------------------------------------------------------
        r1 = T8Pos(5, '')
        IDENT(r1, '       5')                         :S(P1)F(F1)
P1      OUTPUT = 'PASS: 1 T8Pos nil map=LPAD'          :(T1)
F1      OUTPUT = 'FAIL: 1 got=[' r1 ']'
T1

* -----------------------------------------------------------------------
*  2: T8Pos with t8Map — ofs=7 in 2-line map (line1: 0-4, line2: 5+)
* -----------------------------------------------------------------------
        t8Map2    = TABLE()
        t8Map2[0] = 1
        t8Map2[5] = 2
        t8Max     = 0
        r2        = T8Pos(7, t8Map2)
        IDENT(r2, '(    2,   3,     2,   3)')         :S(P2)F(F2)
P2      OUTPUT = 'PASS: 2 T8Pos map line/col'          :(T2)
F2      OUTPUT = 'FAIL: 2 got=[' r2 ']'
T2

* -----------------------------------------------------------------------
*  3: T8Pos updates t8Max
* -----------------------------------------------------------------------
        t8Max2b   = TABLE()
        t8Max2b[0] = 1
        t8Max      = 0
        T8Pos(12, t8Max2b)
        EQ(t8Max, 12)                                  :S(P3)F(F3)
P3      OUTPUT = 'PASS: 3 T8Pos updates t8Max'         :(T3)
F3      OUTPUT = 'FAIL: 3 t8Max=' t8Max
T3

* -----------------------------------------------------------------------
*  4: T8Trace doDebug=0 => sets T8Trace=.dummy (STRING), NRETURNs
* -----------------------------------------------------------------------
        doDebug   = 0
        r4        = T8Trace(1, 'hello', 0)
        IDENT(DATATYPE(r4), dSTRING)                   :S(P4)F(F4)
P4      OUTPUT = 'PASS: 4 T8Trace doDebug=0 returns STRING' :(T4)
F4      OUTPUT = 'FAIL: 4 datatype=' DATATYPE(r4)
T4

* -----------------------------------------------------------------------
*  5: T8Trace doDebug=1, lvl=2 => LE(2,1) fails => NRETURN
* -----------------------------------------------------------------------
        doDebug   = 1
        t8Max     = 0 ; t8MaxLine = 0 ; strOfs = 0 ; t8Map = ''
        r5        = T8Trace(2, 'skip', 0)
        IDENT(DATATYPE(r5), dSTRING)                   :S(P5)F(F5)
P5      OUTPUT = 'PASS: 5 T8Trace lvl>doDebug NRETURN'  :(T5)
F5      OUTPUT = 'FAIL: 5 datatype=' DATATYPE(r5)
T5

* -----------------------------------------------------------------------
*  6: T8Trace doDebug=1, lvl=1, str='?x' => '?' match => NRETURN
* -----------------------------------------------------------------------
        doDebug   = 1
        t8Max     = 0 ; t8MaxLine = 621 ; t8MaxLast = 0 ; strOfs = 0 ; t8Map = ''
        r6        = T8Trace(1, '?x', 0)
        IDENT(DATATYPE(r6), dSTRING)                   :S(P6)F(F6)
P6      OUTPUT = 'PASS: 6 T8Trace ?-prefix doDebug=1 NRETURN' :(T6)
F6      OUTPUT = 'FAIL: 6 datatype=' DATATYPE(r6)
T6

* -----------------------------------------------------------------------
*  7: T8Trace t8MaxLine < 621 => GE guard fails => NRETURN
* -----------------------------------------------------------------------
        doDebug   = 2
        t8Max     = 0 ; t8MaxLine = 0 ; t8MaxLast = 0 ; strOfs = 0 ; t8Map = ''
        r7        = T8Trace(1, 'blocked', 0)
        IDENT(DATATYPE(r7), dSTRING)                   :S(P7)F(F7)
P7      OUTPUT = 'PASS: 7 T8Trace t8MaxLine<621 NRETURN' :(T7)
F7      OUTPUT = 'FAIL: 7 datatype=' DATATYPE(r7)
T7

* -----------------------------------------------------------------------
*  8: T8Trace doDebug=2, str='?node', t8MaxLine=621 => outputs '       0? node'
* -----------------------------------------------------------------------
        doDebug   = 2
        t8Max     = 0 ; t8MaxLine = 621 ; t8MaxLast = 0 ; strOfs = 0 ; t8Map = ''
        OUTPUT    = '--- test 8 output follows ---'
        T8Trace(1, '?node', 0)
        OUTPUT    = 'PASS: 8 T8Trace doDebug=2 ?-expand output'
        :(T8)
T8

* -----------------------------------------------------------------------
*  9: t8MaxLast updated when t8Max >= t8MaxLast
* -----------------------------------------------------------------------
        doDebug   = 2
        t8Max     = 10 ; t8MaxLine = 621 ; t8MaxLast = 5 ; strOfs = 0 ; t8Map = ''
        T8Trace(1, 'upd', 0)
        EQ(t8MaxLast, 10)                              :S(P9)F(F9)
P9      OUTPUT = 'PASS: 9 t8MaxLast updated to t8Max'   :(T9)
F9      OUTPUT = 'FAIL: 9 t8MaxLast=' t8MaxLast
T9

END
