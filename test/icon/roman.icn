# SCRIP DEMO3 -- Roman Numerals (Icon section)
# Idiom: greedy subtraction loop with parallel vals/syms lists
procedure roman(n)
    vals := [1000,900,500,400,100,90,50,40,10,9,5,4,1];
    syms := ["M","CM","D","CD","C","XC","L","XL","X","IX","V","IV","I"];
    result := "";
    every i := 1 to *vals do {
        while n >= vals[i] do {
            result ||:= syms[i];
            n -:= vals[i];
        };
    };
    return result;
end

procedure main()
    write(roman(1776));
    write(roman(42));
    write(roman(9));
end
