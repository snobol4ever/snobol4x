* expr_parser.sno — Expression parser in SNOBOL4
* Translated mechanically from Expressions.py (ByrdBox)
* Each Python generator function becomes a named SNOBOL4 pattern
*
* parse_item:
*   SPAN('0123456789') | 'x' | 'y' | 'z' | '(' parse_term ')'
*
* parse_element:
*   parse_item | '+' parse_element | '-' parse_element
*
* parse_factor:
*   parse_element | parse_element '*' parse_factor | parse_element '/' parse_factor
*
* parse_term:
*   parse_factor | parse_factor '+' parse_term | parse_factor '-' parse_term
*
* parse_expression:
*   POS(0) parse_term RPOS(0)

        DEFINE('ITEM()')
        DEFINE('ELEMENT()')
        DEFINE('FACTOR()')
        DEFINE('TERM()')
        DEFINE('EXPRESSION()')

* ── ITEM ──────────────────────────────────────────────────────────────────
ITEM    SUBJECT SPAN('0123456789')          :S(ITEM.OK)
        SUBJECT LIT('x')                    :S(ITEM.OK)
        SUBJECT LIT('y')                    :S(ITEM.OK)
        SUBJECT LIT('z')                    :S(ITEM.OK)
        SUBJECT LIT('(')                    :F(ITEM.FAIL)
        TERM()                              :F(ITEM.FAIL)
        SUBJECT LIT(')')                    :F(ITEM.FAIL)
ITEM.OK                                     :(RETURN)
ITEM.FAIL                                   :F(FRETURN)

* ── ELEMENT ───────────────────────────────────────────────────────────────
ELEMENT ITEM()                              :S(ELEMENT.OK)
        SUBJECT LIT('+')                    :F(ELEMENT.TRY.MINUS)
        ELEMENT()                           :S(ELEMENT.OK) F(ELEMENT.TRY.MINUS)
ELEMENT.TRY.MINUS
        SUBJECT LIT('-')                    :F(ELEMENT.FAIL)
        ELEMENT()                           :S(ELEMENT.OK) F(ELEMENT.FAIL)
ELEMENT.OK                                  :(RETURN)
ELEMENT.FAIL                                :(FRETURN)

END
