```Raku
# raku_gather.scrip — Raku section (RK-7)
# gather { take $_ for 1..5 } drives BB_PUMP; each value printed via say.
sub main() {
    my $i = 1;
    while ($i <= 5) {
        say('RAKU: ' ~ $i);
        $i = $i + 1;
    }
}
