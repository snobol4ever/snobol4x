; =============================================================================
; Session 174: integer-literal 2-arg fast paths
; CONC2_VI fn, varlab, n   — fn(variable, int)     → [rbp-32/24]
; CONC2_IV fn, n, varlab   — fn(int, variable)     → [rbp-32/24]
; CONC2_II fn, n1, n2      — fn(int, int)           → [rbp-32/24]
