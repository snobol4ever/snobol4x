; =============================================================================
; snobol4_asm.mac — NASM macro library for sno2c ASM backend
;
; Design: every emitted line follows the three-column SNOBOL4 form:
;
;   LABEL          ACTION          GOTO
;
; Macros expand to whatever register shuffling is needed underneath.
; The generated .s file reads like the theory — Byrd box ports visible,
; statement structure clear, no raw register names in the body.
;
; Calling convention: SysV AMD64.
; DESCR_t = 16 bytes: [0..7]=type+pad (rax), [8..15]=union ptr/int (rdx)
; subject_data, subject_len_val, cursor: flat .bss globals.
;
; Registers reserved across macros:
;   rbx = scratch (callee-saved, restored by macros that use it)
;   rax, rdx = DESCR_t return value from C shims
;   rdi, rsi, rdx, rcx = C call arguments
;
; Sprint A12 — M-ASM-MACROS
; =============================================================================

; -----------------------------------------------------------------------------
; STMT_SEP — visual separator between statements (80 columns)
; -----------------------------------------------------------------------------
%macro STMT_SEP 0
    ; ========================================================================
%endmacro

; -----------------------------------------------------------------------------
; PORT_SEP — visual separator between Byrd box ports (60 columns)
; -----------------------------------------------------------------------------
%macro PORT_SEP 0
    ; ----------------------------------------
%endmacro

; -----------------------------------------------------------------------------
; STMT_COMMENT label, text — annotate a statement boundary
; -----------------------------------------------------------------------------
%macro STMT_COMMENT 2
    ; STMT %1 : %2
%endmacro

; -----------------------------------------------------------------------------
; PORT_COMMENT port, role — annotate a Byrd box port
; -----------------------------------------------------------------------------
%macro PORT_COMMENT 2
    ; PORT %1 [%2]
%endmacro

; =============================================================================
; STATEMENT-LEVEL MACROS
; =============================================================================

; -----------------------------------------------------------------------------
; PROG_INIT — program startup: call stmt_init
; -----------------------------------------------------------------------------
%macro PROG_INIT 0
    ; Save callee-saved registers BEFORE frame so rbp-relative slots are clean
    push    r15             ; callee-saved — reserve
    push    r14             ; callee-saved — reserve
    push    r13             ; callee-saved — ARBNO depth
    push    r12             ; callee-saved — SPAN/ANY position
    push    rbx             ; callee-saved — Byrd box scratch
    ; Establish frame
    push    rbp
    mov     rbp, rsp
    ; Allocate DESCR_t temporaries: [rbp-16]=subj, [rbp-32]=rhs, [rbp-48]=spare
    ; 56 bytes: aligns rsp to 16 (entry rsp%16=8, +6 pushes×8=48, +56=112, 112%16=0)
    sub     rsp, 56
    call    stmt_init
%endmacro

; -----------------------------------------------------------------------------
; PROG_END — program termination
; -----------------------------------------------------------------------------
%macro PROG_END 0
    call    stmt_finish
    xor     eax, eax
    add     rsp, 56         ; reclaim DESCR_t slots
    pop     rbp             ; restore frame
    pop     rbx             ; restore callee-saved (reverse order)
    pop     r12
    pop     r13
    pop     r14
    pop     r15
    ret
%endmacro

; -----------------------------------------------------------------------------
; GET_VAR strlab — load named SNOBOL4 variable → DESCR_t at [rbp-16]
; strlab is a S_N label pointing to the null-terminated variable name
; -----------------------------------------------------------------------------
%macro GET_VAR 1
    lea     rdi, [rel %1]
    call    stmt_get
    mov     [rbp-16], rax
    mov     [rbp-8],  rdx
%endmacro

; -----------------------------------------------------------------------------
; SET_VAR strlab — store DESCR_t from [rbp-32] into named variable
; -----------------------------------------------------------------------------
%macro SET_VAR 1
    lea     rdi, [rel %1]
    mov     rsi, [rbp-32]
    mov     rdx, [rbp-24]
    call    stmt_set
%endmacro

; -----------------------------------------------------------------------------
; SET_OUTPUT — write DESCR_t at [rbp-32] to OUTPUT (stdout)
; -----------------------------------------------------------------------------
%macro SET_OUTPUT 0
    mov     rdi, [rbp-32]
    mov     rsi, [rbp-24]
    call    stmt_output
%endmacro

; -----------------------------------------------------------------------------
; LOAD_STR strlab — make string literal DESCR_t at [rbp-32]
; -----------------------------------------------------------------------------
%macro LOAD_STR 1
    lea     rdi, [rel %1]
    call    stmt_strval
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

; -----------------------------------------------------------------------------
; LOAD_INT n — make integer DESCR_t at [rbp-32]
; -----------------------------------------------------------------------------
%macro LOAD_INT 1
    mov     rdi, %1
    call    stmt_intval
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

; -----------------------------------------------------------------------------
; LOAD_REAL flab — make real (double) DESCR_t at [rbp-32]
;   flab is a .data label holding a 64-bit IEEE 754 double (dq)
; -----------------------------------------------------------------------------
%macro LOAD_REAL 1
    lea     rdi, [rel %1]
    call    stmt_realval
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

; -----------------------------------------------------------------------------
; CHECK_FAIL succeed, fail — branch on IS_FAIL of [rbp-32]
; -----------------------------------------------------------------------------
%macro CHECK_FAIL 2
    mov     rdi, [rbp-32]
    mov     rsi, [rbp-24]
    call    stmt_is_fail
    test    eax, eax
    jnz     %2
    jmp     %1
%endmacro

; -----------------------------------------------------------------------------
; SETUP_SUBJECT — copy DESCR_t at [rbp-16] into subject_data for pattern match
; -----------------------------------------------------------------------------
%macro SETUP_SUBJECT 0
    mov     rdi, [rbp-16]
    mov     rsi, [rbp-8]
    call    stmt_setup_subject
%endmacro

; -----------------------------------------------------------------------------
; APPLY_REPL strlab — write DESCR_t at [rbp-32] back to named variable
; -----------------------------------------------------------------------------
%macro APPLY_REPL 1
    lea     rdi, [rel %1]
    mov     rsi, [rbp-32]
    mov     rdx, [rbp-24]
    call    stmt_apply_replacement
%endmacro

; APPLY_REPL_SPLICE varlab, scan_start_sym
; Splice replacement into subject: prefix + repl + suffix.
; repl DESCR_t is in [rbp-32/24]; match_start in scan_start_sym bss slot;
; match_end is current cursor value.
; Calls stmt_apply_replacement_splice(varname, repl, match_start, match_end).
%macro APPLY_REPL_SPLICE 2
    lea     rdi, [rel %1]       ; varname
    mov     rsi, [rbp-32]       ; repl.v
    mov     rdx, [rbp-24]       ; repl.s
    mov     rcx, [%2]           ; match_start
    mov     r8,  [cursor]       ; match_end (= cursor after match)
    call    stmt_apply_replacement_splice
%endmacro

; =============================================================================
; PATTERN NODE MACROS
; Each macro corresponds to one Byrd box primitive.
; Parameters: charset/literal data label, then γ (succeed) and ω (fail) targets.
; =============================================================================

; -----------------------------------------------------------------------------
; LIT_MATCH cs_label, len, γ, ω
; Match exact byte sequence. Inline repe cmpsb.
; -----------------------------------------------------------------------------
%macro LIT_MATCH 4
    ; LIT [%1] len=%2  →  γ=%3  ω=%4
    mov     rax, [rel cursor]
    mov     rbx, [rel subject_len_val]
    mov     rcx, %2
    add     rcx, rax
    cmp     rcx, rbx
    ja      %4
    lea     rsi, [rel %1]
    lea     rdi, [rel subject_data]
    add     rdi, rax
    push    rcx
    mov     rcx, %2
    repe    cmpsb
    pop     rcx
    jne     %4
    mov     [rel cursor], rcx
    jmp     %3
%endmacro

; -----------------------------------------------------------------------------
; SPAN_MATCH cs_label, cs_len, γ, ω
; Match longest run of chars in charset (min 1).
; -----------------------------------------------------------------------------
%macro SPAN_MATCH 4
    ; SPAN [%1] len=%2  →  γ=%3  ω=%4
    mov     rax, [rel cursor]
    mov     rbx, [rel subject_len_val]
    mov     r8,  rax          ; start position
%%span_loop:
    cmp     rax, rbx
    jge     %%span_check
    movzx   ecx, byte [rel subject_data + rax]
    lea     rsi, [rel %1]
    mov     rdx, %2
    push    rax
    push    rbx
    push    r8
%%span_scan:
    test    rdx, rdx
    jz      %%span_notfound
    movzx   edi, byte [rsi]
    cmp     cl, dil
    je      %%span_found
    inc     rsi
    dec     rdx
    jmp     %%span_scan
%%span_found:
    pop     r8
    pop     rbx
    pop     rax
    inc     rax
    jmp     %%span_loop
%%span_notfound:
    pop     r8
    pop     rbx
    pop     rax
%%span_check:
    cmp     rax, r8
    je      %4
    mov     [rel cursor], rax
    jmp     %3
%endmacro

; -----------------------------------------------------------------------------
; POS_MATCH n, γ, ω — match if cursor == n
; -----------------------------------------------------------------------------
%macro POS_MATCH 3
    ; POS %1  →  γ=%2  ω=%3
    cmp     qword [rel cursor], %1
    je      %2
    jmp     %3
%endmacro

; -----------------------------------------------------------------------------
; RPOS_MATCH n, γ, ω — match if cursor == subject_len - n
; -----------------------------------------------------------------------------
%macro RPOS_MATCH 3
    ; RPOS %1  →  γ=%2  ω=%3
    mov     rax, [rel subject_len_val]
    sub     rax, %1
    cmp     [rel cursor], rax
    je      %2
    jmp     %3
%endmacro

; -----------------------------------------------------------------------------
; CURSOR_SAVE reg — save cursor into register (for ALT/ARBNO backtrack)
; -----------------------------------------------------------------------------
%macro CURSOR_SAVE 1
    mov     %1, [rel cursor]
%endmacro

; -----------------------------------------------------------------------------
; CURSOR_RESTORE reg — restore cursor from register
; -----------------------------------------------------------------------------
%macro CURSOR_RESTORE 1
    mov     [rel cursor], %1
%endmacro

; -----------------------------------------------------------------------------
; GOTO_ALWAYS target — unconditional jump (readable alias)
; -----------------------------------------------------------------------------
%macro GOTO_ALWAYS 1
    jmp     %1
%endmacro

; -----------------------------------------------------------------------------
; GOTO_S target — jump on success (alias for clarity in statement context)
; -----------------------------------------------------------------------------
%macro GOTO_S 1
    jmp     %1
%endmacro

; -----------------------------------------------------------------------------
; GOTO_F target — jump on failure
; -----------------------------------------------------------------------------
%macro GOTO_F 1
    jmp     %1
%endmacro

; -----------------------------------------------------------------------------
; CALL_FN name — call a C shim function (readable alias)
; -----------------------------------------------------------------------------
%macro CALL_FN 1
    call    %1
%endmacro

; -----------------------------------------------------------------------------
; STORE_ARG32 slot — copy DESCR_t from [rbp-32]/[rbp-24] into arg array [rsp+slot]
; slot is the byte offset (ai * 16)
; -----------------------------------------------------------------------------
%macro STORE_ARG32 1
    mov     rax, [rbp-32]
    mov     [rsp + %1], rax
    mov     rax, [rbp-24]
    mov     [rsp + %1 + 8], rax
%endmacro

; -----------------------------------------------------------------------------
; STORE_ARG16 slot — copy DESCR_t from [rbp-16]/[rbp-8] into arg array [rsp+slot]
; -----------------------------------------------------------------------------
%macro STORE_ARG16 1
    mov     rax, [rbp-16]
    mov     [rsp + %1], rax
    mov     rax, [rbp-8]
    mov     [rsp + %1 + 8], rax
%endmacro

; -----------------------------------------------------------------------------
; LOAD_NULVCL — load null/void descriptor into [rbp-16]/[rbp-8] AND rax/rdx
; DT_SNUL=0, slen=0, ptr=0.  Callers that do "mov [r12+N], rax" after this
; macro get the correct zero type tag; do NOT use value 1 (that is DT_S).
; -----------------------------------------------------------------------------
%macro LOAD_NULVCL 0
    xor     eax, eax
    xor     edx, edx
    mov     qword [rbp-16], rax
    mov     qword [rbp-8],  rdx
%endmacro

; -----------------------------------------------------------------------------
; LOAD_NULVCL32 — load null/void descriptor into [rbp-32]/[rbp-24]
; DT_SNUL=0.  Mirrors LOAD_NULVCL fix — never use 1 (DT_S) here.
; -----------------------------------------------------------------------------
%macro LOAD_NULVCL32 0
    mov     qword [rbp-32], 0
    mov     qword [rbp-24], 0
%endmacro

; LOAD_FAILDESCR32 — load failure descriptor (DT_FAIL=99) into [rbp-32]/[rbp-24]
; Used by ucall ω return path so FAIL_BR after call site takes :F branch.
; -----------------------------------------------------------------------------
%macro LOAD_FAILDESCR32 0
    mov     qword [rbp-32], 99
    mov     qword [rbp-24], 0
%endmacro

; -----------------------------------------------------------------------------
; APPLY_FN_0 fnlab — call stmt_apply(fnlab, NULL, 0) → result at [rbp-16]/[rbp-8]
; -----------------------------------------------------------------------------
%macro APPLY_FN_0 1
    lea     rdi, [rel %1]
    xor     rsi, rsi
    xor     rdx, rdx
    call    stmt_apply
%endmacro

; -----------------------------------------------------------------------------
; APPLY_FN_N fnlab, nargs — call stmt_apply(fnlab, rsp, nargs)
; Caller must have already built args array on stack (sub rsp, nargs*16)
; and filled slot [rsp+ai*16] for each arg.
; -----------------------------------------------------------------------------
%macro APPLY_FN_N 2
    lea     rdi, [rel %1]
    mov     rsi, rsp
    mov     rdx, %2
    call    stmt_apply
%endmacro

; -----------------------------------------------------------------------------
; SET_CAPTURE varlab, buflab, lenlab
; Materialise a $ capture buffer into a SNOBOL4 variable
; -----------------------------------------------------------------------------
%macro SET_CAPTURE 3
    lea     rdi, [rel %1]
    lea     rsi, [rel %2]
    mov     rdx, [%3]
    call    stmt_set_capture
%endmacro

; -----------------------------------------------------------------------------
; CALL_APPLY fnlab — call stmt_apply with args already on stack
; rdi=fnlab rsi=rsp rdx=nargs must be set by caller before this macro
; This is the tail of the APPLY sequence — just the call + result save.
; -----------------------------------------------------------------------------
%macro CALL_APPLY 0
    call    stmt_apply
%endmacro

; -----------------------------------------------------------------------------
; FAIL_BR fail_lbl — branch to fail_lbl if DESCR_t at [rbp-32] is fail
; -----------------------------------------------------------------------------
%macro FAIL_BR 1
    mov     rdi, [rbp-32]
    mov     rsi, [rbp-24]
    call    stmt_is_fail
    test    eax, eax
    jnz     %1
%endmacro
%define IS_FAIL_BRANCH FAIL_BR      ; back-compat alias

; -----------------------------------------------------------------------------
; FAIL_BR16 fail_lbl — branch if DESCR_t at [rbp-16] is fail
; -----------------------------------------------------------------------------
%macro FAIL_BR16 1
    mov     rdi, [rbp-16]
    mov     rsi, [rbp-8]
    call    stmt_is_fail
    test    eax, eax
    jnz     %1
%endmacro
%define IS_FAIL_BRANCH16 FAIL_BR16  ; back-compat alias

; -----------------------------------------------------------------------------
; LOAD_VAR strlab — load named variable → DESCR_t at [rbp-32] (rhs slot)
; -----------------------------------------------------------------------------
%macro LOAD_VAR 1
    lea     rdi, [rel %1]
    call    stmt_get
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

; -----------------------------------------------------------------------------
; SUBJ_FROM16 — set up subject from DESCR_t at [rbp-16]
; -----------------------------------------------------------------------------
%macro SUBJ_FROM16 0
    mov     rdi, [rbp-16]
    mov     rsi, [rbp-8]
    call    stmt_setup_subject
%endmacro
%define SETUP_SUBJECT_FROM16 SUBJ_FROM16  ; back-compat alias

; =============================================================================
; END snobol4_asm.mac
; =============================================================================

; =============================================================================
; PATTERN NODE PORT MACROS  (Sprint A14 — M-ASM-BEAUTIFUL)
;
; Design: each macro is ONE LINE at the call site — label/action/goto.
; The macro expands to the full instruction sequence for that Byrd box port.
; Local labels use NASM %define + uid counter so each expansion is unique.
;
; Calling convention:
;   cursor         = flat .bss qword label
;   subj           = flat .bss/data byte array label
;   subj_len       = flat .bss qword label
;   charset / lstr = .data label (lit_intern / cs_intern)
;   saved          = per-node .bss qword (caller declares in .bss section)
;   γ / ω  = target labels (passed as macro args)
;
; Each α port: check → match → save cursor → advance → jmp γ, else jmp ω
; Each β port: restore cursor → jmp ω
; =============================================================================

; =============================================================================
; STORE_RESULT — absorb post-APPLY_FN raw mov pair into a named macro
; After APPLY_FN_N/APPLY_FN_0, result is in rax/rdx. Save to [rbp-32/24].
; =============================================================================
%macro STORE_RESULT 0
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

; =============================================================================
; STORE_RESULT16 — save rax/rdx to [rbp-16/8] (subject/lhs slot)
; =============================================================================
%macro STORE_RESULT16 0
    mov     [rbp-16], rax
    mov     [rbp-8],  rdx
%endmacro

; =============================================================================
; SAVE_DESCR — save rax/rdx DESCR_t into [rbp-32/24] (same as STORE_RESULT,
; named SAVE_DESCR for pre-call staging context — semantically clearer)
; =============================================================================
%macro SAVE_DESCR 0
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

; =============================================================================
; LIT_α lstr, len, saved, cursor, subj, subj_len, γ, ω
;   α port for a literal string match.
;   lstr    = .data label for the literal bytes
;   len     = literal length (integer constant)
;   saved   = .bss qword for cursor save/restore
;   cursor  = .bss qword
;   subj    = subject byte array label
;   subj_len= .bss qword
;   γ   = success target
;   ω   = failure target
; =============================================================================
%macro LIT_α 8            ; lstr, len, saved, cursor, subj, subj_len, γ, ω
    mov     rax, [%4]         ; rax = cursor
    add     rax, %2           ; rax = cursor + len
    cmp     rax, [%6]         ; past end?
    jg      %8                ; → ω
    lea     rsi, [rel %5]     ; rsi = &subject[0]
    mov     rcx, [%4]         ; rcx = cursor
    add     rsi, rcx          ; rsi = &subject[cursor]
    lea     rdi, [rel %1]     ; rdi = &lstr[0]
    mov     rcx, %2           ; rcx = len
    repe    cmpsb             ; compare
    jne     %8                ; mismatch → ω
    mov     rax, [%4]         ; save original cursor
    mov     [%3], rax
    add     rax, %2           ; advance
    mov     [%4], rax
    jmp     %7                ; → γ
%endmacro

; LIT_α1 lbyte, saved, cursor, subj, subj_len, γ, ω
;   Optimised single-byte literal — no repe cmpsb overhead
%macro LIT_α1 7           ; byte_val, saved, cursor, subj, subj_len, γ, ω
    mov     rax, [%3]         ; rax = cursor
    cmp     rax, [%5]         ; at end?
    jge     %7                ; → ω
    lea     rbx, [rel %4]     ; rbx = &subject[0]
    movzx   ecx, byte [rbx + rax]  ; ecx = subject[cursor]
    cmp     cl, %1            ; match byte?
    jne     %7                ; → ω
    mov     [%2], rax         ; save cursor
    inc     rax
    mov     [%3], rax
    jmp     %6                ; → γ
%endmacro

; LIT_β saved, cursor, ω
%macro LIT_β 3             ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; LIT_VAR_α varlab, saved, cursor, γ, ω
;   α port: match subject at cursor against the runtime string value of variable varlab.
;   Uses stmt_match_var(varname) which fetches the var, does memcmp, advances cursor.
;   saved = .bss qword for cursor save (for β restore on backtrack).
; =============================================================================
%macro LIT_VAR_α 5        ; varlab, saved, cursor, γ, ω
    mov     rax, [%3]
    mov     [%2], rax
    lea     rdi, [rel %1]
    call    stmt_match_var
    test    eax, eax
    jz      %5
    jmp     %4
%endmacro

; LIT_VAR_β saved, cursor, ω
%macro LIT_VAR_β 3         ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; CALL_PAT_α descr_t, descr_p, saved, cursor, γ, ω
;   α port: match using a pre-evaluated DESCR_t in two .bss qwords (type, ptr).
;   stmt_match_descr dispatches DT_P through the pattern engine or does string match.
;   saved = .bss qword for cursor save.
; =============================================================================
%macro CALL_PAT_α 6        ; descr_t, descr_p, saved, cursor, γ, ω
    mov     rax, [%4]
    mov     [%3], rax        ; save cursor for β restore
    mov     rdi, [%1]        ; vtype
    mov     rsi, [%2]        ; vptr
    call    stmt_match_descr
    test    eax, eax
    jz      %6
    jmp     %5
%endmacro

; CALL_PAT_β saved, cursor, ω
%macro CALL_PAT_β 3         ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; POS_α n, cursor, γ, ω
; =============================================================================
%macro POS_α 4            ; n, cursor, γ, ω
    cmp     qword [%2], %1
    jne     %4
    jmp     %3
%endmacro

; POS_β cursor, ω  (no saved needed — POS is pure test)
%macro POS_β 2             ; cursor, ω
    jmp     %2
%endmacro

; POS_α_VAR varlab, cursor, γ, ω
; =============================================================================
%macro POS_α_VAR 4        ; varlab, cursor, γ, ω
    lea     rdi, [rel %1]
    mov     rsi, [%2]
    call    stmt_pos_var
    test    eax, eax
    jz      %4
    jmp     %3
%endmacro

; =============================================================================
; RPOS_α n, cursor, subj_len, γ, ω
; =============================================================================
%macro RPOS_α 5           ; n, cursor, subj_len, γ, ω
    mov     rax, [%3]
%if %1 != 0
    sub     rax, %1
%endif
    cmp     [%2], rax
    jne     %5
    jmp     %4
%endmacro

%macro RPOS_β 2            ; cursor, ω
    jmp     %2
%endmacro

; RPOS_α_VAR varlab, cursor, subj_len, γ, ω
; =============================================================================
%macro RPOS_α_VAR 5       ; varlab, cursor, subj_len, γ, ω
    lea     rdi, [rel %1]
    mov     rsi, [%2]
    mov     rdx, [%3]
    call    stmt_rpos_var
    test    eax, eax
    jz      %5
    jmp     %4
%endmacro

; =============================================================================
; SPAN_α_VAR varlab, saved, cursor, subj, subj_len, γ, ω
;   SPAN with variable charset — calls stmt_span_var, returns new cursor or -1
; =============================================================================
%macro SPAN_α_VAR 7       ; varlab, saved, cursor, subj, subj_len, γ, ω
    mov     rax, [%3]
    mov     [%2], rax
    lea     rdi, [rel %1]
    mov     rsi, [%3]
    lea     rdx, [rel %4]
    mov     rcx, [%5]
    call    stmt_span_var
    cmp     rax, -1
    je      %7
    mov     [%3], rax
    jmp     %6
%endmacro

%macro SPAN_β_VAR 3        ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; BREAK_α_VAR varlab, saved, cursor, subj, subj_len, γ, ω
;   BREAK with variable charset — calls stmt_break_var
; =============================================================================
%macro BREAK_α_VAR 7      ; varlab, saved, cursor, subj, subj_len, γ, ω
    mov     rax, [%3]
    mov     [%2], rax
    lea     rdi, [rel %1]
    mov     rsi, [%3]
    lea     rdx, [rel %4]
    mov     rcx, [%5]
    call    stmt_break_var
    cmp     rax, -1
    je      %7
    mov     [%3], rax
    jmp     %6
%endmacro

%macro BREAK_β_VAR 3       ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; BREAK_α_PTR tlab, plab, saved, cursor, subj, subj_len, γ, ω
; Like BREAK_α_VAR but takes pre-evaluated DESCR_t fields (BSS slots) directly.
; Calls stmt_break_ptr(vtype, vptr, cursor, subj, subj_len) — no hash lookup.
; =============================================================================
%macro BREAK_α_PTR 8       ; tlab, plab, saved, cursor, subj, subj_len, γ, ω
    mov     rax, [%4]
    mov     [%3], rax
    mov     rdi, [rel %1]       ; vtype
    mov     rsi, [rel %2]       ; vptr
    mov     rdx, [%4]           ; cursor
    lea     rcx, [rel %5]       ; subj
    mov     r8,  [%6]           ; subj_len
    call    stmt_break_ptr
    cmp     rax, -1
    je      %8
    mov     [%4], rax
    jmp     %7
%endmacro

%macro BREAK_β_PTR 3       ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; SPAN_α_PTR tlab, plab, saved, cursor, subj, subj_len, γ, ω
; =============================================================================
%macro SPAN_α_PTR 8        ; tlab, plab, saved, cursor, subj, subj_len, γ, ω
    mov     rax, [%4]
    mov     [%3], rax
    mov     rdi, [rel %1]       ; vtype
    mov     rsi, [rel %2]       ; vptr
    mov     rdx, [%4]           ; cursor
    lea     rcx, [rel %5]       ; subj
    mov     r8,  [%6]           ; subj_len
    call    stmt_span_ptr
    cmp     rax, -1
    je      %8
    mov     [%4], rax
    jmp     %7
%endmacro

%macro SPAN_β_PTR 3        ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro


;   BREAKX with variable charset — fails on zero advance
; =============================================================================
%macro BREAKX_α_VAR 7     ; varlab, saved, cursor, subj, subj_len, γ, ω
    mov     rax, [%3]
    mov     [%2], rax
    lea     rdi, [rel %1]
    mov     rsi, [%3]
    lea     rdx, [rel %4]
    mov     rcx, [%5]
    call    stmt_breakx_var
    cmp     rax, -1
    je      %7
    mov     [%3], rax
    jmp     %6
%endmacro

%macro BREAKX_β_VAR 3      ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; BREAKX_α_LIT cslab, saved, cursor, subj, subj_len, γ, ω
;   BREAKX with literal charset — fails on zero advance
; =============================================================================
%macro BREAKX_α_LIT 7     ; cslab, saved, cursor, subj, subj_len, γ, ω
    mov     rax, [%3]
    mov     [%2], rax
    lea     rdi, [rel %1]
    mov     rsi, [%3]
    lea     rdx, [rel %4]
    mov     rcx, [%5]
    call    stmt_breakx_lit
    cmp     rax, -1
    je      %7
    mov     [%3], rax
    jmp     %6
%endmacro

%macro BREAKX_β_LIT 3      ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; ANY_α_VAR varlab, saved, cursor, subj, subj_len, γ, ω
; =============================================================================
%macro ANY_α_VAR 7        ; varlab, saved, cursor, subj, subj_len, γ, ω
    mov     rax, [%3]
    mov     [%2], rax
    lea     rdi, [rel %1]
    mov     rsi, [%3]
    lea     rdx, [rel %4]
    mov     rcx, [%5]
    call    stmt_any_var
    test    eax, eax
    jz      %7
    mov     rax, [%3]
    inc     rax
    mov     [%3], rax
    jmp     %6
%endmacro

%macro ANY_β_VAR 3         ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; ANY_α_PTR tlab, plab, saved, cursor, subj, subj_len, γ, ω
; Like ANY_α_VAR but takes pre-evaluated DESCR_t fields (BSS slots) directly.
; Calls stmt_any_ptr(vtype, vptr, cursor, subj, subj_len) — no hash lookup.
; =============================================================================
%macro ANY_α_PTR 8        ; tlab, plab, saved, cursor, subj, subj_len, γ, ω
    mov     rax, [%4]
    mov     [%3], rax
    mov     rdi, [rel %1]       ; vtype
    mov     rsi, [rel %2]       ; vptr
    mov     rdx, [%4]           ; cursor
    lea     rcx, [rel %5]       ; subj
    mov     r8,  [%6]           ; subj_len
    call    stmt_any_ptr
    test    eax, eax
    jz      %8
    mov     rax, [%4]
    inc     rax
    mov     [%4], rax
    jmp     %7
%endmacro

; ANY_β_PTR is identical to ANY_β_VAR — just restore cursor on backtrack
%macro ANY_β_PTR 3         ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; NOTANY_α_VAR varlab, saved, cursor, subj, subj_len, γ, ω
; =============================================================================
%macro NOTANY_α_VAR 7     ; varlab, saved, cursor, subj, subj_len, γ, ω
    mov     rax, [%3]
    mov     [%2], rax
    lea     rdi, [rel %1]
    mov     rsi, [%3]
    lea     rdx, [rel %4]
    mov     rcx, [%5]
    call    stmt_notany_var
    test    eax, eax
    jz      %7
    mov     rax, [%3]
    inc     rax
    mov     [%3], rax
    jmp     %6
%endmacro

%macro NOTANY_β_VAR 3      ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; AT_α varlab, cursor, γ, ω
;   @VAR cursor-position capture: store cursor as integer into VAR, always succeed
; =============================================================================
%macro AT_α 4             ; varlab, cursor, γ, ω
    lea     rdi, [rel %1]
    mov     rsi, [%2]
    call    stmt_at_capture
    jmp     %3
%endmacro

%macro AT_β 1              ; ω
    jmp     %1
%endmacro

; =============================================================================
; ANY_α cslab, cslen, saved, cursor, subj, subj_len, γ, ω
;   Match one char IN charset.  Inner scan loop is inlined.
; =============================================================================
%macro ANY_α 8            ; cslab, cslen, saved, cursor, subj, subj_len, γ, ω
    mov     rax, [%4]
    cmp     rax, [%6]
    jge     %8
    mov     [%3], rax
    lea     rbx, [rel %5]
    movzx   ecx, byte [rbx + rax]
    lea     rsi, [rel %1]
    mov     rdx, %2
%%any_loop:
    test    rdx, rdx
    jz      %8
    movzx   eax, byte [rsi]
    cmp     al, cl
    je      %%any_found
    inc     rsi
    dec     rdx
    jmp     %%any_loop
%%any_found:
    mov     rax, [%3]
    inc     rax
    mov     [%4], rax
    jmp     %7
%endmacro

%macro ANY_β 3             ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; NOTANY_α cslab, cslen, saved, cursor, subj, subj_len, γ, ω
; =============================================================================
%macro NOTANY_α 8         ; cslab, cslen, saved, cursor, subj, subj_len, γ, ω
    mov     rax, [%4]
    cmp     rax, [%6]
    jge     %8
    mov     [%3], rax
    lea     rbx, [rel %5]
    movzx   ecx, byte [rbx + rax]
    lea     rsi, [rel %1]
    mov     rdx, %2
%%nany_loop:
    test    rdx, rdx
    jz      %%nany_found
    movzx   eax, byte [rsi]
    cmp     al, cl
    je      %8
    inc     rsi
    dec     rdx
    jmp     %%nany_loop
%%nany_found:
    mov     rax, [%3]
    inc     rax
    mov     [%4], rax
    jmp     %7
%endmacro

%macro NOTANY_β 3          ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; SPAN_α cslab, cslen, saved, cursor, subj, subj_len, γ, ω
;   Match longest run (≥1) of chars IN charset.
; =============================================================================
%macro SPAN_α 8           ; cslab, cslen, saved, cursor, subj, subj_len, γ, ω
    mov     rax, [%4]
    cmp     rax, [%6]
    jge     %8
    mov     [%3], rax
    mov     r13, rax
%%span_outer:
    cmp     r13, [%6]
    jge     %%span_done
    lea     rbx, [rel %5]
    movzx   ecx, byte [rbx + r13]
    lea     rsi, [rel %1]
    mov     rdx, %2
%%span_scan:
    test    rdx, rdx
    jz      %%span_done
    movzx   eax, byte [rsi]
    cmp     al, cl
    je      %%span_hit
    inc     rsi
    dec     rdx
    jmp     %%span_scan
%%span_hit:
    inc     r13
    jmp     %%span_outer
%%span_done:
    mov     rbx, [%3]
    cmp     r13, rbx
    je      %8
    mov     [%4], r13
    jmp     %7
%endmacro

%macro SPAN_β 3            ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; BREAK_α cslab, cslen, saved, cursor, subj, subj_len, γ, ω
;   Match longest run of chars NOT IN charset (stop AT delimiter).
; =============================================================================
%macro BREAK_α 8          ; cslab, cslen, saved, cursor, subj, subj_len, γ, ω
    mov     rax, [%4]
    mov     [%3], rax
    mov     r13, rax
%%brk_outer:
    cmp     r13, [%6]
    jge     %8
    lea     rbx, [rel %5]
    movzx   ecx, byte [rbx + r13]
    lea     rsi, [rel %1]
    mov     rdx, %2
%%brk_scan:
    test    rdx, rdx
    je      %%brk_advance
    movzx   eax, byte [rsi]
    cmp     al, cl
    je      %%brk_hit
    inc     rsi
    dec     rdx
    jmp     %%brk_scan
%%brk_advance:
    inc     r13
    jmp     %%brk_outer
%%brk_hit:
    mov     [%4], r13
    jmp     %7
%endmacro

%macro BREAK_β 3           ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; LEN_α n, saved, cursor, subj_len, γ, ω
; =============================================================================
%macro LEN_α 6            ; n, saved, cursor, subj_len, γ, ω
    mov     rax, [%3]
    mov     [%2], rax
    add     rax, %1
    cmp     rax, [%4]
    jg      %6
    mov     [%3], rax
    jmp     %5
%endmacro

%macro LEN_β 3             ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; TAB_α n, saved, cursor, γ, ω
; =============================================================================
%macro TAB_α 5            ; n, saved, cursor, γ, ω
    mov     rax, [%3]
    mov     [%2], rax
    cmp     rax, %1
    jg      %5
    mov     qword [%3], %1
    jmp     %4
%endmacro

%macro TAB_β 3             ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; RTAB_α n, saved, cursor, subj_len, γ, ω
; =============================================================================
%macro RTAB_α 6           ; n, saved, cursor, subj_len, γ, ω
    mov     rax, [%3]
    mov     [%2], rax
    mov     rbx, [%4]
    sub     rbx, %1
    cmp     rax, rbx
    jg      %6
    mov     [%3], rbx
    jmp     %5
%endmacro

%macro RTAB_β 3            ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; REM_α saved, cursor, subj_len, γ
;   REM always succeeds — advances cursor to end.  No β recovery needed.
; =============================================================================
%macro REM_α 4            ; saved, cursor, subj_len, γ
    mov     rax, [%2]
    mov     [%1], rax
    mov     rax, [%3]
    mov     [%2], rax
    jmp     %4
%endmacro

%macro REM_β 3             ; saved, cursor, ω
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; SEQ_α left_α
; SEQ_β  right_β
;   SEQ wiring is pure label redirection — no instructions needed.
;   These macros emit only the jump, making the wiring explicit.
; =============================================================================
%macro SEQ_α 1            ; left_α
    jmp     %1
%endmacro

%macro SEQ_β 1             ; right_β
    jmp     %1
%endmacro

; =============================================================================
; ALT_SAVE_CURSOR saved, cursor  — save cursor at ALT entry
; ALT_RESTORE_CURSOR saved, cursor — restore at left-ω trampoline
; =============================================================================
%macro ALT_SAVE_CURSOR 2      ; saved, cursor
    mov     rax, [%2]
    mov     [%1], rax
%endmacro

%macro ALT_RESTORE_CURSOR 2   ; saved, cursor
    mov     rax, [%1]
    mov     [%2], rax
%endmacro

; =============================================================================
; END of Sprint A14 pattern port macros
; =============================================================================

; =============================================================================
; DOL_SAVE entry_cur, cursor, child_α
;   α port of $ capture: save entry cursor, jump to child
; =============================================================================
%macro DOL_SAVE 3             ; entry_cur, cursor, child_α
    mov     rax, [%2]
    mov     [%1], rax
    jmp     %3
%endmacro

; =============================================================================
; DOL_CAPTURE entry_cur, cursor, cap_buf, cap_len, subj, γ
;   γ port of $ capture: compute span length, copy bytes, jump γ
; =============================================================================
%macro DOL_CAPTURE 6          ; entry_cur, cursor, cap_buf, cap_len, subj, γ
    mov     rax, [%2]         ; rax = cursor (end of match)
    mov     rbx, [%1]         ; rbx = entry cursor (start of match)
    sub     rax, rbx          ; rax = span length
    mov     [%4], rax         ; cap_len = length
    lea     rsi, [rel %5]     ; rsi = &subj[0]
    add     rsi, rbx          ; rsi = &subj[entry_cursor]
    lea     rdi, [rel %3]     ; rdi = cap_buf
    mov     rcx, rax          ; rcx = length
    rep     movsb             ; copy span → cap_buf
    jmp     %6                ; → γ
%endmacro

; =============================================================================
; ALT_α cursor_save, cursor, left_α
;   Combined: save cursor + jump to left arm (α of ALT node)
; =============================================================================
%macro ALT_α 3            ; cursor_save, cursor, left_α
    mov     rax, [%2]
    mov     [%1], rax
    jmp     %3
%endmacro

; =============================================================================
; ALT_ω cursor_save, cursor, right_α
;   Combined: restore cursor + jump to right arm (left_ω trampoline)
; =============================================================================
%macro ALT_ω 3            ; cursor_save, cursor, right_α
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; END of Sprint A14 DOL/ALT combined macros
; =============================================================================

; =============================================================================
; Session 167 — M-ASM-BEAUTIFUL high-level statement macros
; =============================================================================
;
; These macros collapse the verbose 5-8 line sequences in the main body into
; single readable lines, matching the readability of the C backend output.
;
; Naming convention:
;   ASSIGN_INT  var, n, fail_lbl   — var := n  (integer literal)
;   ASSIGN_STR  var, s, fail_lbl   — var := s  (string literal)
;   CALL1_INT   fn, n              — rax/rdx := fn(n)  [result at rbp-32/24]
;   CALL1_STR   fn, s              — rax/rdx := fn(s)  [result at rbp-32/24]
;   CALL1_VAR   fn, var            — rax/rdx := fn(var) [result at rbp-32/24]
;   CONC2       fn, s1, s2         — rax/rdx := CONCAT(s1, s2)  [two str args]
;   CONC2_N     fn, s              — rax/rdx := CONCAT(s, NULVCL)
;   ALT2        fn, s1, s2         — rax/rdx := ALT(s1, s2)     [two str args]
;   ALT2_N      fn, s              — rax/rdx := ALT(s, NULVCL)
;
;   CONC2/ALT2 differ only in fn label; share the same expansion shape.
;   Back-compat aliases: CALL2_SS = CONC2, CALL2_SN = CONC2_N
;
; All ASSIGN_* macros jump to fail_lbl on fail, otherwise store and fall through.

; -----------------------------------------------------------------------------
; ASSIGN_INT var, n, fail_lbl
;   var = n   where n is an integer literal
;   Expands to: LOAD_INT + IS_FAIL_BRANCH + SET_VAR  (was 6 lines)
; -----------------------------------------------------------------------------
%macro ASSIGN_INT 3           ; var_strlab, n, fail_lbl
    mov     rdi, %2
    call    stmt_intval
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
    mov     rdi, [rbp-32]
    mov     rsi, [rbp-24]
    call    stmt_is_fail
    test    rax, rax
    jnz     %3
    lea     rdi, [rel %1]
    mov     rsi, [rbp-32]
    mov     rdx, [rbp-24]
    call    stmt_set
%endmacro

; -----------------------------------------------------------------------------
; ASSIGN_STR var, strlab, fail_lbl
;   var = "string"
;   Expands to: LOAD_STR + IS_FAIL_BRANCH + SET_VAR  (was 6 lines)
; -----------------------------------------------------------------------------
%macro ASSIGN_STR 3           ; var_strlab, str_strlab, fail_lbl
    lea     rdi, [rel %2]
    call    stmt_strval
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
    mov     rdi, [rbp-32]
    mov     rsi, [rbp-24]
    call    stmt_is_fail
    test    rax, rax
    jnz     %3
    lea     rdi, [rel %1]
    mov     rsi, [rbp-32]
    mov     rdx, [rbp-24]
    call    stmt_set
%endmacro

; -----------------------------------------------------------------------------
; ASSIGN_NULL var
;   var =   (null assignment — clears var to empty string / NULVCL)
; -----------------------------------------------------------------------------
%macro ASSIGN_NULL 1          ; var_strlab
    lea     rdi, [rel %1]
    call    stmt_set_null
%endmacro

; -----------------------------------------------------------------------------
; SET_VAR_INDIR
;   $name = val  — indirect assignment: [rbp-16/8] = name DESCR_t, [rbp-32/24] = val DESCR_t
; -----------------------------------------------------------------------------
%macro SET_VAR_INDIR 0
    mov     rdi, [rbp-16]
    mov     rsi, [rbp-8]
    mov     rdx, [rbp-32]
    mov     rcx, [rbp-24]
    call    stmt_set_indirect
%endmacro

; -----------------------------------------------------------------------------
; CALL1_INT fn, n
;   [rbp-32/24] = fn(n)   — 1-arg call with integer literal arg
;   Collapses: sub rsp,16 / LOAD_INT / mov-pair / STORE_ARG32 0 /
;              APPLY_FN_N / add rsp,16 / mov-pair  (was 9 lines → 1)
; -----------------------------------------------------------------------------
%macro CALL1_INT 2            ; fn_strlab, n
    sub     rsp, 16
    mov     rdi, %2
    call    stmt_intval
    mov     [rsp], rax
    mov     [rsp+8], rdx
    lea     rdi, [rel %1]
    mov     rsi, rsp
    mov     rdx, 1
    call    stmt_apply
    add     rsp, 16
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

; -----------------------------------------------------------------------------
; CALL1_STR fn, strlab
;   [rbp-32/24] = fn(s)   — 1-arg call with string literal arg
; -----------------------------------------------------------------------------
%macro CALL1_STR 2            ; fn_strlab, str_strlab
    sub     rsp, 16
    lea     rdi, [rel %2]
    call    stmt_strval
    mov     [rsp], rax
    mov     [rsp+8], rdx
    lea     rdi, [rel %1]
    mov     rsi, rsp
    mov     rdx, 1
    call    stmt_apply
    add     rsp, 16
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

; CALL1_VAR fn, varlab
;   [rbp-32/24] = fn(var)  — 1-arg call with variable arg
; -----------------------------------------------------------------------------
%macro CALL1_VAR 2            ; fn_strlab, var_strlab
    sub     rsp, 16
    lea     rdi, [rel %2]
    call    stmt_get
    mov     [rsp], rax
    mov     [rsp+8], rdx
    lea     rdi, [rel %1]
    mov     rsi, rsp
    mov     rdx, 1
    call    stmt_apply
    add     rsp, 16
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

; -----------------------------------------------------------------------------
; CONC2 fn, strlab1, strlab2   — fn(s1, s2)  two string-literal args → [rbp-32/24]
; ALT2  fn, strlab1, strlab2   — same shape, different fn
; -----------------------------------------------------------------------------
%macro CONC2 3                ; fn_strlab, str1_strlab, str2_strlab
    sub     rsp, 32
    lea     rdi, [rel %2]
    call    stmt_strval
    mov     [rsp], rax
    mov     [rsp+8], rdx
    lea     rdi, [rel %3]
    call    stmt_strval
    mov     [rsp+16], rax
    mov     [rsp+24], rdx
    lea     rdi, [rel %1]
    mov     rsi, rsp
    mov     rdx, 2
    call    stmt_apply
    add     rsp, 32
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro
%define ALT2     CONC2        ; same expansion, caller passes different fn label
%define CALL2_SS CONC2        ; back-compat

; -----------------------------------------------------------------------------
; CONC2_N fn, strlab   — fn(s, NULVCL)  → [rbp-32/24]
; ALT2_N  fn, strlab   — same shape
; -----------------------------------------------------------------------------
%macro CONC2_N 2              ; fn_strlab, str_strlab
    sub     rsp, 32
    lea     rdi, [rel %2]
    call    stmt_strval
    mov     [rsp], rax
    mov     [rsp+8], rdx
    mov     qword [rsp+16], 1
    mov     qword [rsp+24], 0
    lea     rdi, [rel %1]
    mov     rsi, rsp
    mov     rdx, 2
    call    stmt_apply
    add     rsp, 32
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro
%define ALT2_N   CONC2_N      ; same expansion
%define CALL2_SN CONC2_N      ; back-compat

; =============================================================================
; Session 171 — variable-arg CONC2/ALT2 fast-path macros
;
;   CONC2_SV  fn, strlab, varlab   — fn(str_literal, variable)
;   CONC2_VS  fn, varlab, strlab   — fn(variable, str_literal)
;   CONC2_VN  fn, varlab           — fn(variable, NULVCL)
;   CONC2_VV  fn, varlab1, varlab2 — fn(variable, variable)
;
;   ALT2_SV / ALT2_VS / ALT2_VN / ALT2_VV — identical expansion, different fn label
; =============================================================================

; CONC2_SV fn, strlab, varlab   — fn(str_literal, variable) → [rbp-32/24]
%macro CONC2_SV 3
    sub     rsp, 32
    lea     rdi, [rel %2]
    call    stmt_strval
    mov     [rsp], rax
    mov     [rsp+8], rdx
    lea     rdi, [rel %3]
    call    stmt_get
    mov     [rsp+16], rax
    mov     [rsp+24], rdx
    lea     rdi, [rel %1]
    mov     rsi, rsp
    mov     rdx, 2
    call    stmt_apply
    add     rsp, 32
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro
%define ALT2_SV  CONC2_SV

; CONC2_VS fn, varlab, strlab   — fn(variable, str_literal) → [rbp-32/24]
%macro CONC2_VS 3
    sub     rsp, 32
    lea     rdi, [rel %2]
    call    stmt_get
    mov     [rsp], rax
    mov     [rsp+8], rdx
    lea     rdi, [rel %3]
    call    stmt_strval
    mov     [rsp+16], rax
    mov     [rsp+24], rdx
    lea     rdi, [rel %1]
    mov     rsi, rsp
    mov     rdx, 2
    call    stmt_apply
    add     rsp, 32
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro
%define ALT2_VS  CONC2_VS

; CONC2_VN fn, varlab   — fn(variable, NULVCL) → [rbp-32/24]
%macro CONC2_VN 2
    sub     rsp, 32
    lea     rdi, [rel %2]
    call    stmt_get
    mov     [rsp], rax
    mov     [rsp+8], rdx
    mov     qword [rsp+16], 1
    mov     qword [rsp+24], 0
    lea     rdi, [rel %1]
    mov     rsi, rsp
    mov     rdx, 2
    call    stmt_apply
    add     rsp, 32
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro
%define ALT2_VN  CONC2_VN

; CONC2_VV fn, varlab1, varlab2 — fn(variable, variable) → [rbp-32/24]
%macro CONC2_VV 3
    sub     rsp, 32
    lea     rdi, [rel %2]
    call    stmt_get
    mov     [rsp], rax
    mov     [rsp+8], rdx
    lea     rdi, [rel %3]
    call    stmt_get
    mov     [rsp+16], rax
    mov     [rsp+24], rdx
    lea     rdi, [rel %1]
    mov     rsi, rsp
    mov     rdx, 2
    call    stmt_apply
    add     rsp, 32
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro
%define ALT2_VV  CONC2_VV

; =============================================================================
; Session 180 — CAT2 family: string-value concatenation via stmt_concat.
;
; Unlike CONC2 (which calls stmt_apply("CONCAT") for pattern concatenation),
; these macros call stmt_concat(a, b) directly — producing a string result.
; Used by prog_emit_expr E_CONC in non-pattern (value) context.
;
;   CAT2_SS  s1, s2          — concat(literal, literal)  → [rbp-32/24]
;   CAT2_SV  s,  varlab      — concat(literal, variable)
;   CAT2_VS  varlab, s       — concat(variable, literal)
;   CAT2_VV  v1, v2          — concat(variable, variable)
;   CAT2_VN  varlab          — concat(variable, "")
;   CAT2_SN  s               — concat(literal,  "")
; =============================================================================

; stmt_concat(DESCR_t a, DESCR_t b) → rax:rdx
; SysV: first DESCR_t in rdi+rsi, second in rdx+rcx

%macro CAT2_SS 2            ; str1, str2  → [rbp-32/24]
    lea     rdi, [rel %1]
    call    stmt_strval
    mov     rsi, rdx           ; a.high = rdx
    mov     rdi, rax           ; a.low  = rax
    lea     rax, [rel %2]
    push    rdi
    push    rsi
    mov     rdi, rax
    call    stmt_strval
    mov     rcx, rdx           ; b.high
    mov     rdx, rax           ; b.low
    pop     rsi
    pop     rdi
    call    stmt_concat
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

%macro CAT2_SV 2            ; strlab, varlab  → [rbp-32/24]
    lea     rdi, [rel %1]
    call    stmt_strval
    mov     rsi, rdx
    mov     rdi, rax
    lea     rax, [rel %2]
    push    rdi
    push    rsi
    mov     rdi, rax
    call    stmt_get
    mov     rcx, rdx
    mov     rdx, rax
    pop     rsi
    pop     rdi
    call    stmt_concat
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

%macro CAT2_VS 2            ; varlab, strlab  → [rbp-32/24]
    lea     rdi, [rel %1]
    call    stmt_get
    mov     rsi, rdx
    mov     rdi, rax
    lea     rax, [rel %2]
    push    rdi
    push    rsi
    mov     rdi, rax
    call    stmt_strval
    mov     rcx, rdx
    mov     rdx, rax
    pop     rsi
    pop     rdi
    call    stmt_concat
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

%macro CAT2_VV 2            ; varlab1, varlab2  → [rbp-32/24]
    lea     rdi, [rel %1]
    call    stmt_get
    mov     rsi, rdx
    mov     rdi, rax
    lea     rax, [rel %2]
    push    rdi
    push    rsi
    mov     rdi, rax
    call    stmt_get
    mov     rcx, rdx
    mov     rdx, rax
    pop     rsi
    pop     rdi
    call    stmt_concat
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

%macro CAT2_VN 1            ; varlab  → [rbp-32/24]  (concat var with "")
    lea     rdi, [rel %1]
    call    stmt_get
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

%macro CAT2_SN 1            ; strlab  → [rbp-32/24]  (concat literal with "")
    lea     rdi, [rel %1]
    call    stmt_strval
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro


;
; Identical to CONC2/ALT2 family but final mov pair targets rbp-16/rbp-8.
; Used when prog_emit_expr is called with rbp_off == -16 (subject position).
;
;   CONC2_16   fn, s1, s2
;   CONC2_N16  fn, s
;   CONC2_SV16 fn, strlab, varlab
;   CONC2_VS16 fn, varlab, strlab
;   CONC2_VN16 fn, varlab
;   CONC2_VV16 fn, varlab1, varlab2
;   ALT2_*16   — identical expansions, different fn label
; =============================================================================

%macro CONC2_16 3              ; fn, str1, str2  → [rbp-16/8]
    sub     rsp, 32
    lea     rdi, [rel %2]
    call    stmt_strval
    mov     [rsp], rax
    mov     [rsp+8], rdx
    lea     rdi, [rel %3]
    call    stmt_strval
    mov     [rsp+16], rax
    mov     [rsp+24], rdx
    lea     rdi, [rel %1]
    mov     rsi, rsp
    mov     rdx, 2
    call    stmt_apply
    add     rsp, 32
    mov     [rbp-16], rax
    mov     [rbp-8],  rdx
%endmacro
%define ALT2_16    CONC2_16

%macro CONC2_N16 2             ; fn, strlab  → [rbp-16/8]
    sub     rsp, 32
    lea     rdi, [rel %2]
    call    stmt_strval
