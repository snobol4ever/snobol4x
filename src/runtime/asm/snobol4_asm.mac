    lea     rdi, [rel %2]
    call    stmt_get
    mov     [rsp], rax
    mov     [rsp+8], rdx
    mov     rdi, %3
    call    stmt_intval
    mov     [rsp+16], rax
    mov     [rsp+24], rdx
    lea     rdi, [rel %1]
    mov     rsi, rsp
    mov     rdx, 2
    call    stmt_apply
    add     rsp, 32
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro
