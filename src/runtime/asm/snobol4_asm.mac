; =============================================================================
; M-MACRO-BOX — B-241: ARBNO port macros
;
; ARBNO_α  dep, stk, cursor, γ
;   α port: initialize depth=0, push cursor onto stk[0], goto γ (zero reps = success)
;
; ARBNO_β  dep, stk, cur_before, cursor, child_α, ω
;   β port: pop stack; save cursor-before-rep; jump to child α (or ω if empty)
;
; ARBNO_α1  dep, stk, cur_before, cursor, γ, ω
;   child_ok port: zero-advance guard; push new cursor; re-succeed (or ω if stalled)
;
; ARBNO_β1  ω
;   child_fail port: unconditional jump to ω
;
; All memory args are bare refs (no brackets) — macros add [brackets] themselves,
; so they accept either a .bss label or an r12+N expression from bref().
; =============================================================================

%macro ARBNO_α 4          ; dep, stk, cursor, γ
    mov     qword [%1], 0
    lea     rbx, [rel %2]
    mov     rax, [%3]
    mov     [rbx], rax
    mov     qword [%1], 1
    jmp     %4
%endmacro

%macro ARBNO_β 6           ; dep, stk, cur_before, cursor, child_α, ω
    mov     rax, [%1]
    test    rax, rax
    jz      %6
    dec     rax
    mov     [%1], rax
    lea     rbx, [rel %2]
    mov     rcx, [rbx + rax*8]
    mov     [%4], rcx
    mov     [%3], rcx
    jmp     %5
%endmacro

%macro ARBNO_α1 6       ; dep, stk, cur_before, cursor, γ, ω
    mov     rax, [%4]
    mov     rbx, [%3]
    cmp     rax, rbx
    je      %6
    mov     rdx, [%1]
    lea     rbx, [rel %2]
    mov     [rbx + rdx*8], rax
    inc     qword [%1]
    jmp     %5
%endmacro

%macro ARBNO_β1 1     ; ω
    jmp     %1
%endmacro

; =============================================================================
; END M-MACRO-BOX ARBNO macros
; =============================================================================

; =============================================================================
; M-MACRO-BOX B-242 additions
;
; ARB_α  arb_start, arb_step, cursor, γ
;   α port: save cursor as start; step=0; goto γ (0-length match first)
;
; ARB_β  arb_start, arb_step, cursor, subj_len, γ, ω
;   β port: inc step; bounds check start+step<=subj_len; advance cursor; goto γ or ω
;
; NAMED_PAT_γ  ret_γ
;   γ trampoline for non-function named pattern: jmp [ret_γ]
;
; NAMED_PAT_ω  ret_ω
;   ω trampoline for non-function named pattern: jmp [ret_ω]
;
; FN_α_INIT
;   Start of function α: self-init r12 to static DATA template (pre-invoke)
;   Arg: safe name of the box (used to derive box_<safe>_data_template label)
;   This is a %macro taking 1 arg: the safe name string — emitted as a label ref.
;
; FN_γ  ret_γ
;   γ trampoline for user-defined function: jmp [ret_γ]
;
; FN_ω  ret_ω
;   ω trampoline for user-defined function: jmp [ret_ω]
;
; Note: bare `jmp` targets (no memory dereference) stay as bare jmp — per design.
; Memory-indirect returns (jmp [ret_slot]) become FN_γ / FN_ω / NAMED_PAT_γ/OMEGA.
; =============================================================================

%macro ARB_α 4            ; arb_start, arb_step, cursor, γ
    mov     rax, [%3]
    mov     [%1], rax
    mov     qword [%2], 0
    jmp     %4
%endmacro

%macro ARB_β 6             ; arb_start, arb_step, cursor, subj_len, γ, ω
    mov     rax, [%2]
    inc     rax
    mov     [%2], rax
    mov     rbx, [%1]
    add     rbx, rax
    cmp     rbx, [%4]
    jg      %6
    mov     [%3], rbx
    jmp     %5
%endmacro

%macro NAMED_PAT_γ 1      ; ret_γ  (memory slot holding return address)
    jmp     [%1]
%endmacro

%macro NAMED_PAT_ω 1      ; ret_ω
    jmp     [%1]
%endmacro

%macro FN_α_INIT 1        ; box_safe_name  (no-op: blk_alloc+memcpy done at call site)
%endmacro

%macro FN_SET_PARAM 1         ; param_varlab  (rdi=varlab, rsi/rdx=arg from arg slots)
    lea     rdi, [rel %1]
    call    stmt_set
%endmacro

%macro FN_CLEAR_VAR 1         ; varlab  (rdi=varlab, rsi/rdx already = NULVCL from r12 slots)
    lea     rdi, [rel %1]
    call    stmt_set
%endmacro

%macro FN_γ 1             ; ret_γ  (memory slot)
    jmp     [%1]
%endmacro

%macro FN_ω 1             ; ret_ω  (memory slot)
    jmp     [%1]
%endmacro

; =============================================================================
; END M-MACRO-BOX B-242 additions
; =============================================================================
