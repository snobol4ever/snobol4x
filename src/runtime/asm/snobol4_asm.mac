; =============================================================================
; snobol4_asm.mac — NASM macro library for sno2c ASM backend
;
; Design: every emitted line follows the three-column SNOBOL4 form:
;
;   LABEL          ACTION          GOTO
;
; Macros expand to whatever register shuffling is needed underneath.
; The generated .s file reads like the theory — Byrd box ports visible,
; statement structure clear, no raw register names in the body.
;
; Calling convention: SysV AMD64.
; DESCR_t = 16 bytes: [0..7]=type+pad (rax), [8..15]=union ptr/int (rdx)
; subject_data, subject_len_val, cursor: flat .bss globals.
;
; Registers reserved across macros:
;   rbx = scratch (callee-saved, restored by macros that use it)
;   rax, rdx = DESCR_t return value from C shims
;   rdi, rsi, rdx, rcx = C call arguments
;
; Sprint A12 — M-ASM-MACROS
; =============================================================================

; -----------------------------------------------------------------------------
; STMT_SEP — visual separator between statements (80 columns)
; -----------------------------------------------------------------------------
%macro STMT_SEP 0
    ; ========================================================================
%endmacro

; -----------------------------------------------------------------------------
; PORT_SEP — visual separator between Byrd box ports (60 columns)
; -----------------------------------------------------------------------------
%macro PORT_SEP 0
    ; ----------------------------------------
%endmacro

; -----------------------------------------------------------------------------
; STMT_COMMENT label, text — annotate a statement boundary
; -----------------------------------------------------------------------------
%macro STMT_COMMENT 2
    ; STMT %1 : %2
%endmacro

; -----------------------------------------------------------------------------
; PORT_COMMENT port, role — annotate a Byrd box port
; -----------------------------------------------------------------------------
%macro PORT_COMMENT 2
    ; PORT %1 [%2]
%endmacro

; =============================================================================
; STATEMENT-LEVEL MACROS
; =============================================================================

; -----------------------------------------------------------------------------
; PROG_INIT — program startup: call stmt_init
; -----------------------------------------------------------------------------
%macro PROG_INIT 0
    ; Save callee-saved registers BEFORE frame so rbp-relative slots are clean
    push    r15             ; callee-saved — reserve
    push    r14             ; callee-saved — reserve
    push    r13             ; callee-saved — ARBNO depth
    push    r12             ; callee-saved — SPAN/ANY position
    push    rbx             ; callee-saved — Byrd box scratch
    ; Establish frame
    push    rbp
    mov     rbp, rsp
    ; Allocate DESCR_t temporaries: [rbp-16]=subj, [rbp-32]=rhs, [rbp-48]=spare
    ; 56 bytes: aligns rsp to 16 (entry rsp%16=8, +6 pushes×8=48, +56=112, 112%16=0)
    sub     rsp, 56
    call    stmt_init
%endmacro

; -----------------------------------------------------------------------------
; PROG_END — program termination
; -----------------------------------------------------------------------------
%macro PROG_END 0
    call    stmt_finish
    xor     eax, eax
    add     rsp, 56         ; reclaim DESCR_t slots
    pop     rbp             ; restore frame
    pop     rbx             ; restore callee-saved (reverse order)
    pop     r12
    pop     r13
    pop     r14
    pop     r15
    ret
%endmacro

; -----------------------------------------------------------------------------
; GET_VAR strlab — load named SNOBOL4 variable → DESCR_t at [rbp-16]
; strlab is a S_N label pointing to the null-terminated variable name
; -----------------------------------------------------------------------------
%macro GET_VAR 1
    lea     rdi, [rel %1]
    call    stmt_get
    mov     [rbp-16], rax
    mov     [rbp-8],  rdx
%endmacro

; -----------------------------------------------------------------------------
; SET_VAR strlab — store DESCR_t from [rbp-32] into named variable
; -----------------------------------------------------------------------------
%macro SET_VAR 1
    lea     rdi, [rel %1]
    mov     rsi, [rbp-32]
    mov     rdx, [rbp-24]
    call    stmt_set
%endmacro

; -----------------------------------------------------------------------------
; SET_OUTPUT — write DESCR_t at [rbp-32] to OUTPUT (stdout)
; -----------------------------------------------------------------------------
%macro SET_OUTPUT 0
    mov     rdi, [rbp-32]
    mov     rsi, [rbp-24]
    call    stmt_output
%endmacro

; -----------------------------------------------------------------------------
; LOAD_STR strlab — make string literal DESCR_t at [rbp-32]
; -----------------------------------------------------------------------------
%macro LOAD_STR 1
    lea     rdi, [rel %1]
    call    stmt_strval
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

; -----------------------------------------------------------------------------
; LOAD_INT n — make integer DESCR_t at [rbp-32]
; -----------------------------------------------------------------------------
%macro LOAD_INT 1
    mov     rdi, %1
    call    stmt_intval
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

; -----------------------------------------------------------------------------
; CHECK_FAIL succeed, fail — branch on IS_FAIL of [rbp-32]
; -----------------------------------------------------------------------------
%macro CHECK_FAIL 2
    mov     rdi, [rbp-32]
    mov     rsi, [rbp-24]
    call    stmt_is_fail
    test    eax, eax
    jnz     %2
    jmp     %1
%endmacro

; -----------------------------------------------------------------------------
; SETUP_SUBJECT — copy DESCR_t at [rbp-16] into subject_data for pattern match
; -----------------------------------------------------------------------------
%macro SETUP_SUBJECT 0
    mov     rdi, [rbp-16]
    mov     rsi, [rbp-8]
    call    stmt_setup_subject
%endmacro

; -----------------------------------------------------------------------------
; APPLY_REPL strlab — write DESCR_t at [rbp-32] back to named variable
; -----------------------------------------------------------------------------
%macro APPLY_REPL 1
    lea     rdi, [rel %1]
    mov     rsi, [rbp-32]
    mov     rdx, [rbp-24]
    call    stmt_apply_replacement
%endmacro

; =============================================================================
; PATTERN NODE MACROS
; Each macro corresponds to one Byrd box primitive.
; Parameters: charset/literal data label, then γ (succeed) and ω (fail) targets.
; =============================================================================

; -----------------------------------------------------------------------------
; LIT_MATCH cs_label, len, γ, ω
; Match exact byte sequence. Inline repe cmpsb.
; -----------------------------------------------------------------------------
%macro LIT_MATCH 4
    ; LIT [%1] len=%2  →  γ=%3  ω=%4
    mov     rax, [rel cursor]
    mov     rbx, [rel subject_len_val]
    mov     rcx, %2
    add     rcx, rax
    cmp     rcx, rbx
    ja      %4
    lea     rsi, [rel %1]
    lea     rdi, [rel subject_data]
    add     rdi, rax
    push    rcx
    mov     rcx, %2
    repe    cmpsb
    pop     rcx
    jne     %4
    mov     [rel cursor], rcx
    jmp     %3
%endmacro

; -----------------------------------------------------------------------------
; SPAN_MATCH cs_label, cs_len, γ, ω
; Match longest run of chars in charset (min 1).
; -----------------------------------------------------------------------------
%macro SPAN_MATCH 4
    ; SPAN [%1] len=%2  →  γ=%3  ω=%4
    mov     rax, [rel cursor]
    mov     rbx, [rel subject_len_val]
    mov     r8,  rax          ; start position
%%span_loop:
    cmp     rax, rbx
    jge     %%span_check
    movzx   ecx, byte [rel subject_data + rax]
    lea     rsi, [rel %1]
    mov     rdx, %2
    push    rax
    push    rbx
    push    r8
%%span_scan:
    test    rdx, rdx
    jz      %%span_notfound
    movzx   edi, byte [rsi]
    cmp     cl, dil
    je      %%span_found
    inc     rsi
    dec     rdx
    jmp     %%span_scan
%%span_found:
    pop     r8
    pop     rbx
    pop     rax
    inc     rax
    jmp     %%span_loop
%%span_notfound:
    pop     r8
    pop     rbx
    pop     rax
%%span_check:
    cmp     rax, r8
    je      %4
    mov     [rel cursor], rax
    jmp     %3
%endmacro

; -----------------------------------------------------------------------------
; POS_MATCH n, γ, ω — match if cursor == n
; -----------------------------------------------------------------------------
%macro POS_MATCH 3
    ; POS %1  →  γ=%2  ω=%3
    cmp     qword [rel cursor], %1
    je      %2
    jmp     %3
%endmacro

; -----------------------------------------------------------------------------
; RPOS_MATCH n, γ, ω — match if cursor == subject_len - n
; -----------------------------------------------------------------------------
%macro RPOS_MATCH 3
    ; RPOS %1  →  γ=%2  ω=%3
    mov     rax, [rel subject_len_val]
    sub     rax, %1
    cmp     [rel cursor], rax
    je      %2
    jmp     %3
%endmacro

; -----------------------------------------------------------------------------
; CURSOR_SAVE reg — save cursor into register (for ALT/ARBNO backtrack)
; -----------------------------------------------------------------------------
%macro CURSOR_SAVE 1
    mov     %1, [rel cursor]
%endmacro

; -----------------------------------------------------------------------------
; CURSOR_RESTORE reg — restore cursor from register
; -----------------------------------------------------------------------------
%macro CURSOR_RESTORE 1
    mov     [rel cursor], %1
%endmacro

; -----------------------------------------------------------------------------
; GOTO_ALWAYS target — unconditional jump (readable alias)
; -----------------------------------------------------------------------------
%macro GOTO_ALWAYS 1
    jmp     %1
%endmacro

; -----------------------------------------------------------------------------
; GOTO_S target — jump on success (alias for clarity in statement context)
; -----------------------------------------------------------------------------
%macro GOTO_S 1
    jmp     %1
%endmacro

; -----------------------------------------------------------------------------
; GOTO_F target — jump on failure
; -----------------------------------------------------------------------------
%macro GOTO_F 1
    jmp     %1
%endmacro

; -----------------------------------------------------------------------------
; CALL_FN name — call a C shim function (readable alias)
; -----------------------------------------------------------------------------
%macro CALL_FN 1
    call    %1
%endmacro

; -----------------------------------------------------------------------------
; STORE_ARG32 slot — copy DESCR_t from [rbp-32]/[rbp-24] into arg array [rsp+slot]
; slot is the byte offset (ai * 16)
; -----------------------------------------------------------------------------
%macro STORE_ARG32 1
    mov     rax, [rbp-32]
    mov     [rsp + %1], rax
    mov     rax, [rbp-24]
    mov     [rsp + %1 + 8], rax
%endmacro

; -----------------------------------------------------------------------------
; STORE_ARG16 slot — copy DESCR_t from [rbp-16]/[rbp-8] into arg array [rsp+slot]
; -----------------------------------------------------------------------------
%macro STORE_ARG16 1
    mov     rax, [rbp-16]
    mov     [rsp + %1], rax
    mov     rax, [rbp-8]
    mov     [rsp + %1 + 8], rax
%endmacro

; -----------------------------------------------------------------------------
; LOAD_NULVCL — load null/void descriptor into [rbp-16]/[rbp-8]
; -----------------------------------------------------------------------------
%macro LOAD_NULVCL 0
    mov     qword [rbp-16], 1
    mov     qword [rbp-8],  0
%endmacro

; -----------------------------------------------------------------------------
; LOAD_NULVCL32 — load null/void descriptor into [rbp-32]/[rbp-24]
; -----------------------------------------------------------------------------
%macro LOAD_NULVCL32 0
    mov     qword [rbp-32], 1
    mov     qword [rbp-24], 0
%endmacro

; -----------------------------------------------------------------------------
; APPLY_FN_0 fnlab — call stmt_apply(fnlab, NULL, 0) → result at [rbp-16]/[rbp-8]
; -----------------------------------------------------------------------------
%macro APPLY_FN_0 1
    lea     rdi, [rel %1]
    xor     rsi, rsi
    xor     rdx, rdx
    call    stmt_apply
%endmacro

; -----------------------------------------------------------------------------
; APPLY_FN_N fnlab, nargs — call stmt_apply(fnlab, rsp, nargs)
; Caller must have already built args array on stack (sub rsp, nargs*16)
; and filled slot [rsp+ai*16] for each arg.
; -----------------------------------------------------------------------------
%macro APPLY_FN_N 2
    lea     rdi, [rel %1]
    mov     rsi, rsp
    mov     rdx, %2
    call    stmt_apply
%endmacro

; -----------------------------------------------------------------------------
; SET_CAPTURE varlab, buflab, lenlab
; Materialise a $ capture buffer into a SNOBOL4 variable
; -----------------------------------------------------------------------------
%macro SET_CAPTURE 3
    lea     rdi, [rel %1]
    lea     rsi, [rel %2]
    mov     rdx, [%3]
    call    stmt_set_capture
%endmacro

; -----------------------------------------------------------------------------
; CALL_APPLY fnlab — call stmt_apply with args already on stack
; rdi=fnlab rsi=rsp rdx=nargs must be set by caller before this macro
; This is the tail of the APPLY sequence — just the call + result save.
; -----------------------------------------------------------------------------
%macro CALL_APPLY 0
    call    stmt_apply
%endmacro

; -----------------------------------------------------------------------------
; IS_FAIL_BRANCH fail_lbl — branch to fail_lbl if DESCR_t at [rbp-32] is fail
; -----------------------------------------------------------------------------
%macro IS_FAIL_BRANCH 1
    mov     rdi, [rbp-32]
    mov     rsi, [rbp-24]
    call    stmt_is_fail
    test    eax, eax
    jnz     %1
%endmacro

; -----------------------------------------------------------------------------
; IS_FAIL_BRANCH16 fail_lbl — branch if DESCR_t at [rbp-16] is fail
; -----------------------------------------------------------------------------
%macro IS_FAIL_BRANCH16 1
    mov     rdi, [rbp-16]
    mov     rsi, [rbp-8]
    call    stmt_is_fail
    test    eax, eax
    jnz     %1
%endmacro

; -----------------------------------------------------------------------------
; LOAD_VAR strlab — load named variable → DESCR_t at [rbp-32] (rhs slot)
; -----------------------------------------------------------------------------
%macro LOAD_VAR 1
    lea     rdi, [rel %1]
    call    stmt_get
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

; -----------------------------------------------------------------------------
; SETUP_SUBJECT_FROM16 — set up subject from DESCR_t at [rbp-16]
; -----------------------------------------------------------------------------
%macro SETUP_SUBJECT_FROM16 0
    mov     rdi, [rbp-16]
    mov     rsi, [rbp-8]
    call    stmt_setup_subject
%endmacro

; =============================================================================
; END snobol4_asm.mac
; =============================================================================

; =============================================================================
; PATTERN NODE PORT MACROS  (Sprint A14 — M-ASM-BEAUTIFUL)
;
; Design: each macro is ONE LINE at the call site — label/action/goto.
; The macro expands to the full instruction sequence for that Byrd box port.
; Local labels use NASM %define + uid counter so each expansion is unique.
;
; Calling convention:
;   cursor         = flat .bss qword label
;   subj           = flat .bss/data byte array label
;   subj_len       = flat .bss qword label
;   charset / lstr = .data label (lit_intern / cs_intern)
;   saved          = per-node .bss qword (caller declares in .bss section)
;   gamma / omega  = target labels (passed as macro args)
;
; Each α port: check → match → save cursor → advance → jmp gamma, else jmp omega
; Each β port: restore cursor → jmp omega
; =============================================================================

; =============================================================================
; STORE_RESULT — absorb post-APPLY_FN raw mov pair into a named macro
; After APPLY_FN_N/APPLY_FN_0, result is in rax/rdx. Save to [rbp-32/24].
; =============================================================================
%macro STORE_RESULT 0
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

; =============================================================================
; SAVE_DESCR — save rax/rdx DESCR_t into [rbp-32/24] (same as STORE_RESULT,
; named SAVE_DESCR for pre-call staging context — semantically clearer)
; =============================================================================
%macro SAVE_DESCR 0
    mov     [rbp-32], rax
    mov     [rbp-24], rdx
%endmacro

; =============================================================================
; LIT_ALPHA lstr, len, saved, cursor, subj, subj_len, gamma, omega
;   α port for a literal string match.
;   lstr    = .data label for the literal bytes
;   len     = literal length (integer constant)
;   saved   = .bss qword for cursor save/restore
;   cursor  = .bss qword
;   subj    = subject byte array label
;   subj_len= .bss qword
;   gamma   = success target
;   omega   = failure target
; =============================================================================
%macro LIT_ALPHA 8            ; lstr, len, saved, cursor, subj, subj_len, gamma, omega
    mov     rax, [%4]         ; rax = cursor
    add     rax, %2           ; rax = cursor + len
    cmp     rax, [%6]         ; past end?
    jg      %8                ; → omega
    lea     rsi, [rel %5]     ; rsi = &subject[0]
    mov     rcx, [%4]         ; rcx = cursor
    add     rsi, rcx          ; rsi = &subject[cursor]
    lea     rdi, [rel %1]     ; rdi = &lstr[0]
    mov     rcx, %2           ; rcx = len
    repe    cmpsb             ; compare
    jne     %8                ; mismatch → omega
    mov     rax, [%4]         ; save original cursor
    mov     [%3], rax
    add     rax, %2           ; advance
    mov     [%4], rax
    jmp     %7                ; → gamma
%endmacro

; LIT_ALPHA1 lbyte, saved, cursor, subj, subj_len, gamma, omega
;   Optimised single-byte literal — no repe cmpsb overhead
%macro LIT_ALPHA1 7           ; byte_val, saved, cursor, subj, subj_len, gamma, omega
    mov     rax, [%3]         ; rax = cursor
    cmp     rax, [%5]         ; at end?
    jge     %7                ; → omega
    lea     rbx, [rel %4]     ; rbx = &subject[0]
    movzx   ecx, byte [rbx + rax]  ; ecx = subject[cursor]
    cmp     cl, %1            ; match byte?
    jne     %7                ; → omega
    mov     [%2], rax         ; save cursor
    inc     rax
    mov     [%3], rax
    jmp     %6                ; → gamma
%endmacro

; LIT_BETA saved, cursor, omega
%macro LIT_BETA 3             ; saved, cursor, omega
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; POS_ALPHA n, cursor, gamma, omega
; =============================================================================
%macro POS_ALPHA 4            ; n, cursor, gamma, omega
    cmp     qword [%2], %1
    jne     %4
    jmp     %3
%endmacro

; POS_BETA cursor, omega  (no saved needed — POS is pure test)
%macro POS_BETA 2             ; cursor, omega
    jmp     %2
%endmacro

; =============================================================================
; RPOS_ALPHA n, cursor, subj_len, gamma, omega
; =============================================================================
%macro RPOS_ALPHA 5           ; n, cursor, subj_len, gamma, omega
    mov     rax, [%3]
%if %1 != 0
    sub     rax, %1
%endif
    cmp     [%2], rax
    jne     %5
    jmp     %4
%endmacro

%macro RPOS_BETA 2            ; cursor, omega
    jmp     %2
%endmacro

; =============================================================================
; ANY_ALPHA cslab, cslen, saved, cursor, subj, subj_len, gamma, omega
;   Match one char IN charset.  Inner scan loop is inlined.
; =============================================================================
%macro ANY_ALPHA 8            ; cslab, cslen, saved, cursor, subj, subj_len, gamma, omega
    mov     rax, [%4]
    cmp     rax, [%6]
    jge     %8
    mov     [%3], rax
    lea     rbx, [rel %5]
    movzx   ecx, byte [rbx + rax]
    lea     rsi, [rel %1]
    mov     rdx, %2
%%any_loop:
    test    rdx, rdx
    jz      %8
    movzx   eax, byte [rsi]
    cmp     al, cl
    je      %%any_found
    inc     rsi
    dec     rdx
    jmp     %%any_loop
%%any_found:
    mov     rax, [%3]
    inc     rax
    mov     [%4], rax
    jmp     %7
%endmacro

%macro ANY_BETA 3             ; saved, cursor, omega
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; NOTANY_ALPHA cslab, cslen, saved, cursor, subj, subj_len, gamma, omega
; =============================================================================
%macro NOTANY_ALPHA 8         ; cslab, cslen, saved, cursor, subj, subj_len, gamma, omega
    mov     rax, [%4]
    cmp     rax, [%6]
    jge     %8
    mov     [%3], rax
    lea     rbx, [rel %5]
    movzx   ecx, byte [rbx + rax]
    lea     rsi, [rel %1]
    mov     rdx, %2
%%nany_loop:
    test    rdx, rdx
    jz      %%nany_found
    movzx   eax, byte [rsi]
    cmp     al, cl
    je      %8
    inc     rsi
    dec     rdx
    jmp     %%nany_loop
%%nany_found:
    mov     rax, [%3]
    inc     rax
    mov     [%4], rax
    jmp     %7
%endmacro

%macro NOTANY_BETA 3          ; saved, cursor, omega
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; SPAN_ALPHA cslab, cslen, saved, cursor, subj, subj_len, gamma, omega
;   Match longest run (≥1) of chars IN charset.
; =============================================================================
%macro SPAN_ALPHA 8           ; cslab, cslen, saved, cursor, subj, subj_len, gamma, omega
    mov     rax, [%4]
    cmp     rax, [%6]
    jge     %8
    mov     [%3], rax
    mov     r12, rax
%%span_outer:
    cmp     r12, [%6]
    jge     %%span_done
    lea     rbx, [rel %5]
    movzx   ecx, byte [rbx + r12]
    lea     rsi, [rel %1]
    mov     rdx, %2
%%span_scan:
    test    rdx, rdx
    jz      %%span_done
    movzx   eax, byte [rsi]
    cmp     al, cl
    je      %%span_hit
    inc     rsi
    dec     rdx
    jmp     %%span_scan
%%span_hit:
    inc     r12
    jmp     %%span_outer
%%span_done:
    mov     rbx, [%3]
    cmp     r12, rbx
    je      %8
    mov     [%4], r12
    jmp     %7
%endmacro

%macro SPAN_BETA 3            ; saved, cursor, omega
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; BREAK_ALPHA cslab, cslen, saved, cursor, subj, subj_len, gamma, omega
;   Match longest run of chars NOT IN charset (stop AT delimiter).
; =============================================================================
%macro BREAK_ALPHA 8          ; cslab, cslen, saved, cursor, subj, subj_len, gamma, omega
    mov     rax, [%4]
    mov     [%3], rax
    mov     r12, rax
%%brk_outer:
    cmp     r12, [%6]
    jge     %8
    lea     rbx, [rel %5]
    movzx   ecx, byte [rbx + r12]
    lea     rsi, [rel %1]
    mov     rdx, %2
%%brk_scan:
    test    rdx, rdx
    je      %%brk_advance
    movzx   eax, byte [rsi]
    cmp     al, cl
    je      %%brk_hit
    inc     rsi
    dec     rdx
    jmp     %%brk_scan
%%brk_advance:
    inc     r12
    jmp     %%brk_outer
%%brk_hit:
    mov     [%4], r12
    jmp     %7
%endmacro

%macro BREAK_BETA 3           ; saved, cursor, omega
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; LEN_ALPHA n, saved, cursor, subj_len, gamma, omega
; =============================================================================
%macro LEN_ALPHA 6            ; n, saved, cursor, subj_len, gamma, omega
    mov     rax, [%3]
    mov     [%2], rax
    add     rax, %1
    cmp     rax, [%4]
    jg      %6
    mov     [%3], rax
    jmp     %5
%endmacro

%macro LEN_BETA 3             ; saved, cursor, omega
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; TAB_ALPHA n, saved, cursor, gamma, omega
; =============================================================================
%macro TAB_ALPHA 5            ; n, saved, cursor, gamma, omega
    mov     rax, [%3]
    mov     [%2], rax
    cmp     rax, %1
    jg      %5
    mov     qword [%3], %1
    jmp     %4
%endmacro

%macro TAB_BETA 3             ; saved, cursor, omega
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; RTAB_ALPHA n, saved, cursor, subj_len, gamma, omega
; =============================================================================
%macro RTAB_ALPHA 6           ; n, saved, cursor, subj_len, gamma, omega
    mov     rax, [%3]
    mov     [%2], rax
    mov     rbx, [%4]
    sub     rbx, %1
    cmp     rax, rbx
    jg      %6
    mov     [%3], rbx
    jmp     %5
%endmacro

%macro RTAB_BETA 3            ; saved, cursor, omega
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; REM_ALPHA saved, cursor, subj_len, gamma
;   REM always succeeds — advances cursor to end.  No beta recovery needed.
; =============================================================================
%macro REM_ALPHA 4            ; saved, cursor, subj_len, gamma
    mov     rax, [%2]
    mov     [%1], rax
    mov     rax, [%3]
    mov     [%2], rax
    jmp     %4
%endmacro

%macro REM_BETA 3             ; saved, cursor, omega
    mov     rax, [%1]
    mov     [%2], rax
    jmp     %3
%endmacro

; =============================================================================
; SEQ_ALPHA left_alpha
; SEQ_BETA  right_beta
;   SEQ wiring is pure label redirection — no instructions needed.
;   These macros emit only the jump, making the wiring explicit.
; =============================================================================
%macro SEQ_ALPHA 1            ; left_alpha
    jmp     %1
%endmacro

%macro SEQ_BETA 1             ; right_beta
    jmp     %1
%endmacro

; =============================================================================
; ALT_SAVE_CURSOR saved, cursor  — save cursor at ALT entry
; ALT_RESTORE_CURSOR saved, cursor — restore at left-omega trampoline
; =============================================================================
%macro ALT_SAVE_CURSOR 2      ; saved, cursor
    mov     rax, [%2]
    mov     [%1], rax
%endmacro

%macro ALT_RESTORE_CURSOR 2   ; saved, cursor
    mov     rax, [%1]
    mov     [%2], rax
%endmacro

; =============================================================================
; END of Sprint A14 pattern port macros
; =============================================================================
